# Docker user (match TrueNAS user — run: id truenas_admin)
DOCKER_UID=950
DOCKER_GID=950

# Job Scheduling
JOB_INTERVAL_HOURS=18  # Minimum hours between job runs (upload batches)

# Gemini API Configuration
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# Optional: OpenAI API (if you want to switch back)
# OPENAI_API_KEY=your_openai_api_key_here
